---
import '../styles/main.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Extensions from '../components/Extensions.astro';
import CLIFeatures from '../components/CLIFeatures.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Envoy Ecosystem - Extensions Marketplace for Envoy Proxy</title>
		<meta name="description" content="Discover, run, and build extensions for Envoy Proxy. A community-driven marketplace with zero-friction developer experience, powered by Tetrate" />
		<style>
			/* Critical CSS to prevent FOUC */
			body { margin: 0; opacity: 0; }
			body.loaded { opacity: 1; transition: opacity 0.2s ease-in; }
		</style>
	</head>
	<body>
		<Header />

		<main>
			<Hero />
			<Features />
			<Extensions />
			<CLIFeatures />
			<CTA />
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Copy button functionality
			document.querySelectorAll('.copy-btn').forEach(btn => {
				btn.addEventListener('click', async () => {
					const codeBlock = btn.previousElementSibling;
					if (codeBlock) {
						await navigator.clipboard.writeText(codeBlock.textContent || '');
						const originalHTML = btn.innerHTML;
						btn.innerHTML = '✓';
						setTimeout(() => {
							btn.innerHTML = originalHTML;
						}, 2000);
					}
				});
			});
		</script>
	</body>
</html>
